{
  "family": "greencart-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::654032995211:role/LabRole",
  "containerDefinitions": [
    {
      "name": "greencart-frontend",
      "image": "654032995211.dkr.ecr.us-east-1.amazonaws.com/greencart-frontend:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ]
}
